# PostgreSQL
POSTGRES_DB=vmto
POSTGRES_USER=vmto
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_PASSWORD=change_me_in_production

# RabbitMQ
RABBITMQ_USER=vmto
RABBITMQ_PASS=change_me_in_production

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=vmto
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_BUCKET=vmto-artifacts

# Application
MOCK_MODE=true
WORKER_REPLICAS=2
VERSION=0.1.0

# CORS
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# JWT (generate a strong 32+ character secret for production)
JWT_SECRET_KEY=change_me_in_production_use_32_chars_min
