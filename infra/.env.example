# PostgreSQL
POSTGRES_DB=vmto
POSTGRES_USER=vmto
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_PASSWORD=change_me_in_production

# RabbitMQ
RABBITMQ_USER=vmto
RABBITMQ_PASS=change_me_in_production

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=vmto
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_BUCKET=vmto-artifacts

# Application
MOCK_MODE=true
WORKER_REPLICAS=2
VERSION=0.1.0

# CORS
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# JWT (使用 32 字元以上的隨機字串，生產環境必須更換)
# 對應 ASP.NET Core 設定路徑：Jwt:SecretKey
Jwt__SecretKey=change_me_in_production_use_32_chars_min_here
Jwt__Issuer=VMTO
Jwt__Audience=VMTO
