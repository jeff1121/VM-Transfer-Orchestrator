# PostgreSQL
POSTGRES_DB=vmto
POSTGRES_USER=vmto
POSTGRES_PASSWORD=change_me_in_production

# RabbitMQ
RABBITMQ_USER=vmto
RABBITMQ_PASS=change_me_in_production

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=vmto
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_BUCKET=vmto-artifacts

# Application
MOCK_MODE=true
WORKER_REPLICAS=2
VERSION=0.2.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_production

# CORS
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Ops automation
ARTIFACT_RETENTION_DAYS=7
STUCK_JOB_THRESHOLD_MINUTES=20
FAILED_JOB_RETRY_DELAY_MINUTES=5
STORAGE_USAGE_THRESHOLD_BYTES=53687091200
BACKUP_BUCKET_NAME=backups
