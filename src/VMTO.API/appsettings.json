{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "MassTransit": "Information",
      "Hangfire": "Information"
    }
  },
  "Serilog": {
    "FilePath": "logs/vmto-api-.json"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=vmto;Username=vmto;Password=vmto_secret",
    "Redis": "localhost:6379",
    "RabbitMQ": "amqp://guest:guest@localhost:5672/",
    "Hangfire": ""
  },
  "Storage": {
    "S3": {
      "Endpoint": "http://localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "BucketName": "vmto-artifacts",
      "UseSSL": false
    }
  },
  "UseMockClients": true,
  "Cors": {
    "Origins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "License": {
    "Enabled": false,
    "ServerUrl": "http://localhost:5200",
    "SigningKey": ""
  },
  "Jwt": {
    "Issuer": "vmto-api",
    "Audience": "vmto-client",
    "SecretKey": "",
    "ExpirationMinutes": 60
  },
  "OpenTelemetry": {
    "ServiceName": "vmto-api",
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    }
  },
  "HealthChecks": {
    "RabbitMQ": {
      "Queues": [
        "export-vmdk",
        "convert-disk",
        "upload-artifact",
        "import-to-pve",
        "verify"
      ]
    },
    "Disk": {
      "Path": "/",
      "MinimumFreeBytes": 10737418240
    }
  },
  "Resilience": {
    "Retry": {
      "MaxRetryAttempts": 5,
      "BaseDelaySeconds": 1,
      "MaxDelaySeconds": 30,
      "RequestTimeoutSeconds": 120,
      "UseJitter": true
    }
  },
  "Chaos": {
    "Enabled": false,
    "FailureRate": 0,
    "MaxDelayMs": 0,
    "TimeoutRate": 0
  },
  "Ops": {
    "ArtifactRetentionDays": 7,
    "StuckJobThresholdMinutes": 20,
    "FailedJobRetryDelayMinutes": 5,
    "StorageUsageThresholdBytes": 53687091200,
    "BackupBucketName": "backups",
    "DatabaseBackupTimeoutSeconds": 300
  }
}
